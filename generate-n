#!/bin/bash
if [ ! -e "./generate-n" ]
then
  echo "Please run this script from the exec directory"
  exit 1
fi

show_generator_options() {
  echo "Generator options:"
  echo "  ./generate-n --versions|-v <number> [--products|-p <number>] [--step|-s <number>] [--target|-t <number>] [--easing|-e <name|expr>] [--patterns|-P <number>] [--concurrent|-c <list>] [--outdir|-o <dir>] [--format|-f <format>] [--var <percentage>]"
  echo "Shortcuts: -v, -p, -s, -t, -e, -P, -c, -o, -f"
  echo ""
  echo "  --products|-p <number>  Initial product count for the first version (default: 100)"
  echo "  --step|-s <number>      Product increment per version, linear mode (default: 1000)"
  echo "  --target|-t <number>    Final product count for the last version. Enables easing mode:"
  echo "                          the count is interpolated from --products to --target along the"
  echo "                          chosen --easing curve. When set, --step is ignored."
  echo "  --easing|-e <name|expr> Easing curve used in easing mode (default: linear). Either a named"
  echo "                          curve or a raw awk expression of t (the version progress, 0..1)."
  echo "                          Named curves:"
  echo "                            linear"
  echo "                            easeInSine  easeOutSine  easeInOutSine"
  echo "                            easeInQuad  easeOutQuad  easeInOutQuad"
  echo "                            easeInCubic easeOutCubic easeInOutCubic"
  echo "                            easeInQuart easeOutQuart easeInOutQuart"
  echo "                            easeInQuint easeOutQuint easeInOutQuint"
  echo "                            easeInExpo  easeOutExpo  easeInOutExpo"
  echo "                            easeInCirc  easeOutCirc  easeInOutCirc"
  echo "                            easeInBack  easeOutBack  easeInOutBack"
  echo "                            easeInElastic easeOutElastic easeInOutElastic"
  echo "                            easeInBounce easeOutBounce easeInOutBounce"
  echo "                          (Back and Elastic overshoot the [products,target] range.)"
  echo "                          Periodic curves (use --patterns to set the number of cycles):"
  echo "                            sineWave    oscillates products<->target, returns to products"
  echo "                            sineStairs  grows to target in 'patterns' steps"
  echo "                          Example custom expression: -e 't*t*t' (same as easeInCubic)"
  echo "  --patterns|-P <number>  Number of cycles for the periodic curves (default: 1). Models"
  echo "                          repeated data-acquisition campaigns. Use --versions >= 4*patterns"
  echo "                          so the waves are well sampled. Ignored by non-periodic curves."
  echo "  --concurrent|-c <list>  Generate several concurrent lineages that share the SAME first"
  echo "                          version but evolve differently. <list> is a comma-separated set of"
  echo "                          branch specs 'curve[@target[@patterns]]' (the optional @target and"
  echo "                          @patterns default to --target and --patterns). Requires --target."
  echo "                          Version 1 is generated once as the shared root (dataset-1) in"
  echo "                          --outdir; each branch's versions 2..N go to its own sub-directory."
  echo "                          Example: -t 5000 -c 'linear,easeInCubic,easeOutExpo,sineWave@5000@4'"
  echo "  --outdir|-o <dir>       Parent directory for --concurrent output (default: concurrent)."
  echo "  --var <percentage>      Variability: percentage of products that change between versions (0-100, default: 0)"
}

# Named easing curves expressed as awk expressions of t (progress in [0,1]).
# The awk BEGIN block provides pi, the constants c1..c5 and the bounceOut()
# function used below. Anything not listed here is treated as a raw awk
# expression of t, so custom curves work out of the box.
# Note: the Back and Elastic curves intentionally overshoot the [0,1] range
# (so product counts may dip below --products or above --target mid-sequence);
# the first and last versions still equal --products and --target exactly.
declare -A EASINGS=(
  [linear]="t"
  [easeInSine]="1-cos(t*pi/2)"
  [easeOutSine]="sin(t*pi/2)"
  [easeInOutSine]="-(cos(pi*t)-1)/2"
  [easeInQuad]="t*t"
  [easeOutQuad]="1-(1-t)*(1-t)"
  [easeInOutQuad]="(t<0.5)?(2*t*t):(1-(-2*t+2)^2/2)"
  [easeInCubic]="t^3"
  [easeOutCubic]="1-(1-t)^3"
  [easeInOutCubic]="(t<0.5)?(4*t^3):(1-(-2*t+2)^3/2)"
  [easeInQuart]="t^4"
  [easeOutQuart]="1-(1-t)^4"
  [easeInOutQuart]="(t<0.5)?(8*t^4):(1-(-2*t+2)^4/2)"
  [easeInQuint]="t^5"
  [easeOutQuint]="1-(1-t)^5"
  [easeInOutQuint]="(t<0.5)?(16*t^5):(1-(-2*t+2)^5/2)"
  [easeInExpo]="(t==0)?0:(2^(10*t-10))"
  [easeOutExpo]="(t==1)?1:(1-2^(-10*t))"
  [easeInOutExpo]="(t==0)?0:((t==1)?1:((t<0.5)?(2^(20*t-10)/2):((2-2^(-20*t+10))/2)))"
  [easeInCirc]="1-sqrt(1-t^2)"
  [easeOutCirc]="sqrt(1-(t-1)^2)"
  [easeInOutCirc]="(t<0.5)?((1-sqrt(1-(2*t)^2))/2):((sqrt(1-(-2*t+2)^2)+1)/2)"
  [easeInBack]="c3*t^3-c1*t^2"
  [easeOutBack]="1+c3*(t-1)^3+c1*(t-1)^2"
  [easeInOutBack]="(t<0.5)?((2*t)^2*((c2+1)*2*t-c2))/2:((2*t-2)^2*((c2+1)*(2*t-2)+c2)+2)/2"
  [easeInElastic]="(t==0)?0:((t==1)?1:(-(2^(10*t-10))*sin((10*t-10.75)*c4)))"
  [easeOutElastic]="(t==0)?0:((t==1)?1:((2^(-10*t))*sin((10*t-0.75)*c4)+1))"
  [easeInOutElastic]="(t==0)?0:((t==1)?1:((t<0.5)?(-(2^(20*t-10))*sin((20*t-11.125)*c5))/2:(2^(-20*t+10))*sin((20*t-11.125)*c5)/2+1))"
  [easeInBounce]="1-bounceOut(1-t)"
  [easeOutBounce]="bounceOut(t)"
  [easeInOutBounce]="(t<0.5)?((1-bounceOut(1-2*t))/2):((1+bounceOut(2*t-1))/2)"
  [sineWave]="(1-cos(2*pi*patterns*t))/2"
  [sineStairs]="t-sin(2*pi*patterns*t)/(2*pi*patterns)"
)

# ease_value <i> <n> <start> <target> <expr> [patterns]
# Echoes the (rounded, >=1) product count for version i of n, interpolating
# from start to target along the easing expression expr (an awk expression of t).
# patterns (default 1) is the cycle count available to periodic curves.
ease_value() {
  local i="$1" n="$2" start="$3" target="$4" expr="$5" patterns="${6:-1}"
  awk -v i="$i" -v n="$n" -v start="$start" -v target="$target" -v patterns="$patterns" '
  # Base bounce curve (easeOutBounce); easeIn/InOut variants are derived from it.
  function bounceOut(x){
    if(x<1/2.75){return 7.5625*x*x}
    else if(x<2/2.75){x-=1.5/2.75; return 7.5625*x*x+0.75}
    else if(x<2.5/2.75){x-=2.25/2.75; return 7.5625*x*x+0.9375}
    else {x-=2.625/2.75; return 7.5625*x*x+0.984375}
  }
  BEGIN{
    pi=3.141592653589793
    # Overshoot constants for the Back and Elastic families (from easings.net).
    c1=1.70158; c3=c1+1; c2=c1*1.525
    c4=(2*pi)/3; c5=(2*pi)/4.5
    t=(n>1)?(i-1)/(n-1):0
    e=('"$expr"')
    v=int(start+e*(target-start)+0.5)
    if(v<1) v=1
    print v
  }'
}

# generate_one <prefix> <products>
# Generates the dataset for one version at <prefix>.<format>, honouring --var
# (which also emits <prefix>_update.nt). Unless the format is already nt, a
# companion N-Triples file is produced for diffing. Echoes (on stdout) the path
# of the N-Triples file to diff against; all progress output goes to stderr.
generate_one() {
  local prefix="$1" pc="$2"
  if [ "$variability" -gt 0 ]; then
    local ppt=$((variability * pc / 100))
    if [ "$ppt" -lt 1 ]; then ppt=1; fi
    echo "  generating update dataset with $ppt products changed ($variability%)" >&2
    ./generate -s "$output_format" -pc "$pc" -fn "$prefix" -ud -tc 1 -ppt "$ppt" -ufn "${prefix}_update" >&2
  else
    ./generate -s "$output_format" -pc "$pc" -fn "$prefix" >&2
  fi

  if [ "$output_format" == "nt" ]; then
    # The dataset itself is already N-Triples, so it doubles as the diff input.
    echo "${prefix}.nt"
  else
    local dir base
    dir=$(dirname "$prefix"); base=$(basename "$prefix")
    echo "  generating N-Triples copy for diff computation" >&2
    ./generate -s nt -pc "$pc" -fn "${dir}/.diff_${base}" >&2
    echo "${dir}/.diff_${base}.nt"
  fi
}

# diff_versions <prev_nt> <curr_nt> <prefix>
# Writes the additions/deletions between two consecutive versions to
# <prefix>_additions.nt and <prefix>_deletions.nt.
diff_versions() {
  local prev="$1" curr="$2" prefix="$3"
  # DatasetDiff loads both N-Triples files into memory and sorts them, so its
  # heap is overridable via BSBM_XMX (e.g. BSBM_XMX=8g) for large versions —
  # the same variable that sizes the generator subprocess.
  java -cp "$CP" -Xmx"${BSBM_XMX:-2g}" benchmark.tools.DatasetDiff \
    "$prev" "$curr" "${prefix}_additions.nt" "${prefix}_deletions.nt"
}

# run_versions <dir> <expr> <target> <patterns> <init_prev_nt> <start_i>
# Generates versions <start_i>..N of one lineage into <dir> (use "." for the
# current directory), diffing each version against the previous one. When
# <init_prev_nt> is non-empty it is the N-Triples file of the version preceding
# <start_i> (a shared root); it is diffed against but never deleted here.
run_versions() {
  local dir="$1" expr="$2" target="$3" patterns="$4" prev_nt="$5" start_i="$6"
  local prev_is_shared=0
  if [ -n "$prev_nt" ]; then prev_is_shared=1; fi
  local i pc pfx curr_nt
  for i in $(seq "$start_i" "$number_of_versions"); do
    if [ "$easing_mode" -eq 1 ]; then
      pc=$(ease_value "$i" "$number_of_versions" "$products_number" "$target" "$expr" "$patterns")
    else
      pc=$((products_number + i * products_step))
    fi
    if [ "$dir" = "." ]; then pfx="dataset-$i"; else pfx="$dir/dataset-$i"; fi
    echo "  version $i: $pc products"
    curr_nt=$(generate_one "$pfx" "$pc")
    if [ -n "$prev_nt" ]; then
      diff_versions "$prev_nt" "$curr_nt" "$pfx"
      if [ "$output_format" != "nt" ] && [ "$prev_is_shared" -eq 0 ]; then
        rm -f "$prev_nt"
      fi
    fi
    prev_nt="$curr_nt"
    prev_is_shared=0
  done
  # Remove the trailing temp NT (kept above as prev for the diff); for the nt
  # format the file is a real dataset, so leave it in place.
  if [ "$output_format" != "nt" ] && [ -n "$prev_nt" ] && [ "$prev_is_shared" -eq 0 ]; then
    rm -f "$prev_nt"
  fi
}

if [ $# == 0 ] || [ "$1" == "-help" ]
then
  show_generator_options
  exit 1
fi

# Default values
output_format="ttl"

# Parse named arguments and shortcuts
while [[ $# -gt 0 ]]; do
  key="$1"
  case $key in
    --versions|-v)
      number_of_versions="$2"
      shift; shift
      ;;
    --products|-p)
      products_number="$2"
      shift; shift
      ;;
    --step|-s)
      products_step="$2"
      shift; shift
      ;;
    --target|-t)
      products_target="$2"
      shift; shift
      ;;
    --easing|-e)
      easing="$2"
      shift; shift
      ;;
    --patterns|-P)
      patterns="$2"
      shift; shift
      ;;
    --concurrent|-c)
      concurrent="$2"
      shift; shift
      ;;
    --outdir|-o)
      outdir="$2"
      shift; shift
      ;;
    --format|-f)
      output_format="$2"
      shift; shift
      ;;
    --var)
      variability="$2"
      shift; shift
      ;;
    -h|--help)
      show_generator_options
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

# Set defaults if not provided
number_of_versions=${number_of_versions:-}
products_number=${products_number:-100}
products_step=${products_step:-1000}
products_target=${products_target:-}
patterns=${patterns:-1}
variability=${variability:-0}
concurrent=${concurrent:-}
outdir=${outdir:-concurrent}

if [ -z "$number_of_versions" ]; then
  echo "Please provide --versions <number> (or -v <number>)"
  exit 1
fi
# check that $number_of_versions is an integer
if ! [[ $number_of_versions =~ ^[0-9]+$ ]]
then
  echo "Please provide an integer for --versions"
  exit 1
fi

# check that variability is an integer between 0 and 100
if ! [[ $variability =~ ^[0-9]+$ ]] || [ "$variability" -lt 0 ] || [ "$variability" -gt 100 ]
then
  echo "Please provide an integer between 0 and 100 for --var"
  exit 1
fi

# check that patterns is a positive integer (number of periodic cycles)
if ! [[ $patterns =~ ^[0-9]+$ ]] || [ "$patterns" -lt 1 ]
then
  echo "Please provide a positive integer for --patterns (or -P)"
  exit 1
fi

# Easing mode is enabled when a --target is provided. Otherwise the legacy
# linear "products + i * step" progression is used.
easing_mode=0
if [ -n "$products_target" ]; then
  easing_mode=1
  if ! [[ $products_target =~ ^[0-9]+$ ]]; then
    echo "Please provide an integer for --target"
    exit 1
  fi
  # Easing interpolates between the first and last version, so it needs at least two.
  if [ "$number_of_versions" -lt 2 ]; then
    echo "Easing mode (--target) requires --versions >= 2"
    exit 1
  fi
  # Default curve is linear, which reproduces an evenly-spaced ramp.
  easing=${easing:-linear}
  # Resolve a named curve, or fall back to treating the value as a raw awk
  # expression of t (the version progress in [0,1]).
  if [ -n "${EASINGS[$easing]+x}" ]; then
    easing_expr="${EASINGS[$easing]}"
  elif [[ $easing =~ ^[A-Za-z][A-Za-z0-9]*$ ]]; then
    # A bare word that isn't a known curve is almost certainly a misspelled curve
    # name. As an awk expression it would be an uninitialized variable (=0),
    # silently flattening every version to --products, so reject it outright.
    echo "Unknown easing curve: '$easing'. Run with -help to list the available curves."
    exit 1
  elif ! [[ $easing =~ (^|[^A-Za-z0-9_])t([^A-Za-z0-9_]|$) ]]; then
    # A custom expression that never references t is a constant (or a typo); it
    # would flatten the progression, so reject it rather than generate bad data.
    echo "Custom --easing expression must be a function of t: '$easing'"
    exit 1
  else
    easing_expr="$easing"
  fi
  # Fail fast if the expression is invalid (awk would otherwise error every
  # version). Check both endpoints (t=0 and t=1) so curves with special-cased
  # boundaries, e.g. the Expo/Elastic guards, are exercised.
  if ! ease_value 1 "$number_of_versions" "$products_number" "$products_target" "$easing_expr" "$patterns" >/dev/null 2>&1 \
     || ! ease_value "$number_of_versions" "$number_of_versions" "$products_number" "$products_target" "$easing_expr" "$patterns" >/dev/null 2>&1; then
    echo "Invalid --easing expression: '$easing'"
    exit 1
  fi
elif [ -n "$easing" ]; then
  echo "--easing requires --target (or -t) to be set; ignoring --easing in linear mode" >&2
fi

# --patterns only affects the periodic easing curves, which require easing mode.
if [ "$patterns" -ne 1 ] && [ "$easing_mode" -ne 1 ]; then
  echo "--patterns only affects periodic easing curves; ignoring it without --target" >&2
fi

# --- Concurrent (multi-lineage) mode -----------------------------------------
# --concurrent lists several branch evolutions that all share the same first
# version (a single generated root) and then diverge. Each spec is
# 'curve[@target[@patterns]]'; the optional fields fall back to --target and
# --patterns. The branches are resolved into parallel arrays here so the
# generation loop below can stay simple.
declare -a br_expr br_target br_patterns br_label br_dir
if [ -n "$concurrent" ]; then
  if [ "$easing_mode" -ne 1 ]; then
    echo "--concurrent requires --target (or -t): branches evolve from --products to a target via easing"
    exit 1
  fi
  if [ -n "$easing" ] && [ "$easing" != "linear" ]; then
    echo "--concurrent overrides the global --easing; each branch uses its own curve" >&2
  fi
  IFS=',' read -ra concurrent_specs <<< "$concurrent"
  branch_index=0
  for spec in "${concurrent_specs[@]}"; do
    # Trim surrounding whitespace so 'a, b' works as well as 'a,b'.
    spec="${spec#"${spec%%[![:space:]]*}"}"
    spec="${spec%"${spec##*[![:space:]]}"}"
    if [ -z "$spec" ]; then continue; fi
    IFS='@' read -r b_easing b_target b_patterns <<< "$spec"
    b_target="${b_target:-$products_target}"
    b_patterns="${b_patterns:-$patterns}"
    # Resolve the curve to an awk expression (same rules as single mode).
    if [ -n "${EASINGS[$b_easing]+x}" ]; then
      b_expr="${EASINGS[$b_easing]}"
    elif [[ $b_easing =~ ^[A-Za-z][A-Za-z0-9]*$ ]]; then
      echo "Unknown easing curve in --concurrent: '$b_easing'. Run with -help to list the curves."
      exit 1
    elif ! [[ $b_easing =~ (^|[^A-Za-z0-9_])t([^A-Za-z0-9_]|$) ]]; then
      echo "Custom curve in --concurrent must be a function of t: '$b_easing'"
      exit 1
    else
      b_expr="$b_easing"
    fi
    if ! [[ $b_target =~ ^[0-9]+$ ]]; then
      echo "Invalid target '$b_target' for branch '$b_easing' in --concurrent"
      exit 1
    fi
    if ! [[ $b_patterns =~ ^[0-9]+$ ]] || [ "$b_patterns" -lt 1 ]; then
      echo "Invalid patterns '$b_patterns' for branch '$b_easing' in --concurrent"
      exit 1
    fi
    if ! ease_value 1 "$number_of_versions" "$products_number" "$b_target" "$b_expr" "$b_patterns" >/dev/null 2>&1 \
       || ! ease_value "$number_of_versions" "$number_of_versions" "$products_number" "$b_target" "$b_expr" "$b_patterns" >/dev/null 2>&1; then
      echo "Invalid easing expression for branch '$b_easing' in --concurrent"
      exit 1
    fi
    # Build a filesystem-safe, human-readable sub-directory name.
    branch_index=$((branch_index + 1))
    label="${b_easing//[^A-Za-z0-9]/_}"
    label="${label#_}"; label="${label%_}"
    if [ -z "$label" ]; then label="curve"; fi
    br_expr+=("$b_expr")
    br_target+=("$b_target")
    br_patterns+=("$b_patterns")
    br_label+=("$b_easing")
    br_dir+=("$(printf 'branch-%02d-%s' "$branch_index" "$label")")
  done
  if [ "${#br_expr[@]}" -eq 0 ]; then
    echo "--concurrent did not contain any branch specifications"
    exit 1
  fi
fi

echo "Generating $number_of_versions versions"
if [ -n "$concurrent" ]; then
  echo "Concurrent mode: ${#br_expr[@]} branch(es) sharing version 1 ($products_number products), output under $outdir/"
  for k in "${!br_expr[@]}"; do
    echo "  branch $((k + 1)): ${br_label[$k]} (target ${br_target[$k]}, patterns ${br_patterns[$k]}) -> $outdir/${br_dir[$k]}/"
  done
elif [ "$easing_mode" -eq 1 ]; then
  echo "Easing mode: products from $products_number to $products_target using '$easing'"
  if [[ $easing == sine* ]]; then
    echo "Periodic mode: $patterns acquisition cycle(s)"
  fi
else
  echo "Setting products to $products_number, products step to $products_step"
fi
echo "Output format: $output_format"
echo "Variability: $variability%"

# Build classpath for Java tools
CP=.
SEP=':'
if [ "$(uname)" = "Cygwin" ]; then SEP=';'; fi
for jar in lib/*.jar
do
  if [ ! -e "$jar" ]; then continue; fi
  CP="$CP$SEP$jar"
done

if [ -n "$concurrent" ]; then
  # Concurrent lineages: generate version 1 once (the shared root), then evolve
  # each branch independently from it into its own sub-directory.
  mkdir -p "$outdir"
  root_products=$(ease_value 1 "$number_of_versions" "$products_number" "$products_target" "${br_expr[0]}" "${br_patterns[0]}")
  echo "Generating shared version 1 ($root_products products) -> $outdir/dataset-1.$output_format"
  shared_nt=$(generate_one "$outdir/dataset-1" "$root_products")

  for k in "${!br_expr[@]}"; do
    branch_dir="$outdir/${br_dir[$k]}"
    mkdir -p "$branch_dir"
    echo "Branch $((k + 1))/${#br_expr[@]}: ${br_label[$k]} (target ${br_target[$k]}, patterns ${br_patterns[$k]}) -> $branch_dir/"
    run_versions "$branch_dir" "${br_expr[$k]}" "${br_target[$k]}" "${br_patterns[$k]}" "$shared_nt" 2
  done

  # The shared-root NT was kept so every branch could diff version 2 against it.
  if [ "$output_format" != "nt" ]; then
    rm -f "$shared_nt"
  fi
  echo "Done: ${#br_expr[@]} concurrent branch(es) under $outdir/ (shared root: dataset-1.$output_format)"
else
  # Single lineage (legacy linear ramp or single-curve easing) in the cwd.
  run_versions "." "$easing_expr" "$products_target" "$patterns" "" 1
fi
