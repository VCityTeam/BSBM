#!/bin/bash
if [ ! -e "./generate" ]
then
  echo "Please run this script from the exec directory"
  exit 1
fi
if [ $# == 0 ]
then
  echo "For generator options type ./generate -help"
fi
CP=.
SEP=':'
if [ "$(uname)" = "Cygwin" ]; then SEP=';'; fi
for jar in lib/*.jar
do
  if [ ! -e "$jar" ]; then continue; fi
  CP="$CP$SEP$jar"
done
# Heap size is overridable via BSBM_XMX (e.g. BSBM_XMX=8g) for large product
# counts; the generator holds the whole model in memory while serializing.
exec java -cp "$CP" -Xmx"${BSBM_XMX:-2g}" benchmark.generator.Generator "$@"
